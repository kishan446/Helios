        "alt": "Block World Game"
      },
      {
        "category": "teacher_avatar",
        "url": "https://images.unsplash.com/photo-1584805207967-3bdf1fa0c000?crop=entropy&cs=srgb&fm=jpg&ixid=M3w4NTYxODl8MHwxfHNlYXJjaHwxfHxjeWJlcnB1bmslMjB0ZWFjaGVyJTIwYXZhdGFyfGVufDB8fHx8MTc3MzU5MTg5MHww&ixlib=rb-4.1.0&q=85",
        "alt": "Teacher Avatar"
      }
    ],
    "icons": "lucide-react"
  },
  "universal_guidelines": {
    "rules": [
      "Do NOT use gradients for text unless it is a very large heading.",
      "Do NOT use 'Inter' for Headings. Use 'Orbitron'.",
      "ALWAYS use 'Space Grotesk' for buttons and inputs.",
      "Ensure all interactive elements have hover states (glow or lift).",
      "Use 'backdrop-blur-md' or 'backdrop-blur-xl' for all overlay panels.",
      "Add 'data-testid' to all interactive elements."
    ]
  },
  "instructions_to_main_agent": {
    "step_1": "Update tailwind.config.js with the new color palette and font families.",
    "step_2": "Update index.css with the CSS variables for the dark theme.",
    "step_3": "Install 'framer-motion', 'lucide-react', 'react-tsparticles', 'tsparticles', 'clsx', 'tailwind-merge'.",
    "step_4": "Create the 'ParticleBackground' component using tsparticles.",
    "step_5": "Create the 'GlitchText' component.",
    "step_6": "Build the 'Hero', 'PromptForge', and 'GameGallery' sections following the design specs."
  }
}